{
  "name": "@plank-cms/addon-content-health",
  "version": "0.1.0",
  "type": "module",
  "description": "Official Plank add-on for content health insights.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plank": {
      "import": "./dist/plank.js",
      "types": "./dist/plank.d.ts"
    },
    "./admin": {
      "import": "./dist/admin.js",
      "types": "./dist/admin.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "http://localhost:4000/api/packages/martirale/npm/"
  },
  "scripts": {
    "build": "pnpm clean && tsc && vite build --config vite.admin.config.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "plank",
    "addon",
    "content-health"
  ],
  "license": "ISC",
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "react": "19.2.5",
    "typescript": "6.0.3",
    "vite": "8.0.9"
  }
}
