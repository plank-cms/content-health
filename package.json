{
  "name": "@plank-cms/addon-content-health",
  "version": "0.1.1",
  "type": "module",
  "description": "Official Plank add-on for content health insights.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plank": {
      "import": "./dist/plank.js",
      "types": "./dist/plank.d.ts"
    },
    "./admin": {
      "import": "./dist/admin.js",
      "types": "./dist/admin.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && tsc && vite build --config vite.admin.config.ts",
    "clean": "rm -rf dist",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "author": {
    "name": "Alejandro Mártir",
    "url": "https://alemartir.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/plank-cms/content-health#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plank-cms/content-health.git"
  },
  "bugs": {
    "url": "https://github.com/plank-cms/content-health/issues"
  },
  "keywords": [
    "cms",
    "headless-cms",
    "plank",
    "plank-cms",
    "addon",
    "content-health",
    "content",
    "editorial"
  ],
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "react": "19.2.5",
    "typescript": "6.0.3",
    "vite": "8.0.9"
  }
}
